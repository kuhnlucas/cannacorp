# ===========================================================
# .env.example — Variables de entorno para CannaCorp
# ===========================================================
# Copiar a .env y completar:  cp .env.example .env
# ===========================================================

# --- Backend ---
JWT_SECRET=cambiar-por-un-string-largo-y-aleatorio
DATABASE_URL=file:./dev.db

# Puerto del backend (default: 3000)
API_PORT=3000

# Puerto del frontend (default: 5173)
WEB_PORT=5173

# --- Tuya IoT (opcional) ---
TUYA_CLIENT_ID=
TUYA_CLIENT_SECRET=
TUYA_REGION=us
TUYA_BASE_URL=

# --- PulseGrow IoT (opcional) ---
PULSE_GROW_API_URL=https://api.pulsegrow.com
PULSE_GROW_API_KEY=

# --- Producción (solo docker-compose.prod.yml) ---
# DB_PASSWORD=cambiar-por-password-seguro
# VITE_API_URL=https://api.tudominio.com/api
