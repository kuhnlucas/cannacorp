# ===========================================================
# .env.example — Variables de entorno para CannaCorp
# ===========================================================
# Copiar a .env y completar:  cp .env.example .env
# ===========================================================

# --- Backend ---
JWT_SECRET=cambiar-por-un-string-largo-y-aleatorio
DATABASE_URL=file:./dev.db

# Puerto del backend (default: 3000)
API_PORT=3000

# Puerto del frontend (default: 5173)
WEB_PORT=5173

# --- Tuya IoT (opcional) ---
TUYA_CLIENT_ID=REPLACE_WITH_YOUR_TUYA_CLIENT_ID
TUYA_CLIENT_SECRET=REPLACE_WITH_YOUR_TUYA_CLIENT_SECRET
TUYA_REGION=us
TUYA_BASE_URL=

# --- PulseGrow IoT (opcional) ---
PULSE_GROW_API_URL=https://api.pulsegrow.com
PULSE_GROW_API_KEY=REPLACE_WITH_YOUR_PULSE_GROW_API_KEY

# --- Edenic (opcional) ---
# API key y Organization ID se obtienen desde Edenic App → Account settings → API Keys
EDENIC_BASE_URL=https://api.edenic.io
EDENIC_API_KEY=REPLACE_WITH_YOUR_EDENIC_API_KEY
EDENIC_ORGANIZATION_ID=REPLACE_WITH_YOUR_EDENIC_ORGANIZATION_ID
EDENIC_TENANT_ID=REPLACE_WITH_YOUR_EDENIC_AUTHORIZED_TENANT_ID
# EDENIC_API_SECRET: no se usa en la integración actual (la API usa header Authorization con API key)
# Puede eliminarse si no existe ningún otro sistema que lo requiera.
# EDENIC_API_SECRET=

# --- Producción (solo docker-compose.prod.yml) ---
# DB_PASSWORD=cambiar-por-password-seguro
# VITE_API_URL=https://api.tudominio.com/api
